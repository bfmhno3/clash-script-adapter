#!/usr/bin/env bash
set -euo pipefail

# 获取 mise 安装包的基础路径
ESBUILD_PREFIX="$(mise where npm:esbuild)"
TERSER_PREFIX="$(mise where npm:terser)"

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*|Windows_NT)
    # Windows 路径结构及分号分隔符
    export NODE_PATH="$ESBUILD_PREFIX/node_modules;$TERSER_PREFIX/node_modules"
    ;;
  *)
    # Linux/macOS 路径结构及冒号分隔符
    export NODE_PATH="$ESBUILD_PREFIX/lib/node_modules:$TERSER_PREFIX/lib/node_modules"
    ;;
esac

node build.js

